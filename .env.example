# Supabase project URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — keep this secret, never expose to the browser
# (found in Project Settings > API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Canonical URL of the deployed app (no trailing slash); used for PDF links, email callbacks, etc.
NEXT_PUBLIC_APP_URL=https://your-app.netlify.app
